# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Notion API
NOTION_API_KEY=your_notion_integration_token_here
# 新規DBを作成する親ページのID（NotionページURLの末尾32文字）
NOTION_PARENT_PAGE_ID=your_notion_parent_page_id_here

# 取得対象期間（時間単位、デフォルト: 24）
# テスト時は 168 (7日間) に変更すると記事が取得しやすい
# HOURS_LOOKBACK=168

# 処理する記事の最大件数（Gemini APIのトークン節約用、未設定時は全件）
# テスト時は 3 などの小さい値を推奨
# MAX_ARTICLES=3

# 取得対象ベンダー（カンマ区切り）
ENABLED_VENDORS="OpenAI,Google,Microsoft,Meta,Anthropic"

# 各ベンダーのフィードURL
FEED_URL_OPENAI="https://openai.com/blog/rss.xml"
FEED_URL_GOOGLE="https://blog.google/technology/ai/rss/"
FEED_URL_MICROSOFT="https://blogs.microsoft.com/ai/feed/"
FEED_URL_META="https://engineering.fb.com/feed/"
# Anthropic は公式RSSなし → Jina Reader 経由でリリースノートを取得
FEED_URL_ANTHROPIC="https://r.jina.ai/https://docs.anthropic.com/en/release-notes"
