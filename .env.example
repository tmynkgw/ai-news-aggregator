# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Notion API
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_notion_database_id_here

# 取得対象期間（時間単位、デフォルト: 24）
# テスト時は 168 (7日間) に変更すると記事が取得しやすい
# HOURS_LOOKBACK=168

# 処理する記事の最大件数（Gemini APIのトークン節約用、未設定時は全件）
# テスト時は 3 などの小さい値を推奨
# MAX_ARTICLES=3